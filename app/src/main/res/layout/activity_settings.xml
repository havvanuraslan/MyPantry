<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F6"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/layoutSettingsBanner"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@drawable/bg_home_top_banner"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnSettingsBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:scaleType="centerInside"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvSettingsTitleInside"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="22dp"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:layout_marginTop="-20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutSettingsBanner"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="NOTIFICATIONS &amp; ALERTS"
                android:textColor="#BCAAA4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="2dp"
                app:strokeColor="#EFE7E2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:paddingHorizontal="20dp">
                        <ImageView
                            android:id="@+id/ivBellIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_popup_reminder"
                            app:tint="#5E3924" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivBellIcon"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:text="Push Notifications"
                            android:textColor="#2D2D2D"
                            android:textSize="15sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchNotifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="#9A5B30"
                            app:trackTint="#EFE7E2"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F0EB" android:layout_marginHorizontal="20dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:paddingHorizontal="20dp">
                        <ImageView
                            android:id="@+id/ivTimerIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_menu_recent_history" app:tint="#5E3924" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivTimerIcon"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:text="Pantry Expiry Alerts"
                            android:textColor="#2D2D2D"
                            android:textSize="15sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchExpiryAlerts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="#9A5B30"
                            app:trackTint="#EFE7E2" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="AI RECIPE PREFERENCES"
                android:textColor="#BCAAA4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="2dp"
                app:strokeColor="#EFE7E2"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:paddingHorizontal="20dp">
                    <ImageView
                        android:id="@+id/ivCpuIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="#5E3924" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivCpuIcon"
                        android:layout_toStartOf="@+id/switchStrictMatch"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Strict Ingredient Matching"
                            android:textColor="#2D2D2D"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Filters recipes strictly by pantry limits"
                            android:textColor="#8C8C8C"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchStrictMatch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        app:thumbTint="#9A5B30"
                        app:trackTint="#EFE7E2" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="SYSTEM &amp; INTERFACE"
                android:textColor="#BCAAA4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="2dp"
                app:strokeColor="#EFE7E2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <RelativeLayout
                        android:id="@+id/layoutLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp">
                        <ImageView
                            android:id="@+id/ivLangIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_menu_mapmode"
                            app:tint="#5E3924" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivLangIcon"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:text="Language"
                            android:textColor="#2D2D2D"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="English  ›"
                            android:textColor="#8C8C8C"
                            android:textSize="14sp" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F0EB" android:layout_marginHorizontal="20dp"/>

                    <RelativeLayout
                        android:id="@+id/layoutTheme"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp">
                        <ImageView
                            android:id="@+id/ivThemeIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_menu_compass"
                            app:tint="#5E3924" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivThemeIcon"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:text="Theme"
                            android:textColor="#2D2D2D"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Light Mode  ›"
                            android:textColor="#8C8C8C"
                            android:textSize="14sp" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 📄 BÖLÜM 4: LEGAL & ABOUT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="ABOUT APP"
                android:textColor="#BCAAA4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="2dp"
                app:strokeColor="#EFE7E2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <!-- Privacy Policy & Terms -->
                    <RelativeLayout
                        android:id="@+id/layoutPrivacy"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp">
                        <ImageView
                            android:id="@+id/ivDocIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="#5E3924" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivDocIcon"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:text="Privacy Policy &amp; Terms"
                            android:textColor="#2D2D2D"
                            android:textSize="15sp" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F0EB" android:layout_marginHorizontal="20dp"/>

                    <!-- 🌟 GÜNCELLENDİ: Help & Support (Yardım ve Destek İkonuyla Beraber) -->
                    <RelativeLayout
                        android:id="@+id/layoutHelpSupport"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp">
                        <ImageView
                            android:id="@+id/ivHelpIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_menu_help"
                            app:tint="#5E3924" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivHelpIcon"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:text="Help &amp; Support"
                            android:textColor="#2D2D2D"
                            android:textSize="15sp" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="2dp"
                app:strokeColor="#EFE7E2"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:id="@+id/layoutClearCache"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="20dp">
                    <ImageView
                        android:id="@+id/ivDeleteIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_delete"
                        app:tint="#BA1A1A" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivDeleteIcon"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="14dp"
                        android:text="Clear Image &amp; Recipe Cache"
                        android:textColor="#BA1A1A"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="MyPantry v1.0.0 Stable"
                android:textColor="#BDBDBD"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>