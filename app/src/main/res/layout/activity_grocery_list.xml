<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F6"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_home_top_banner"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/white"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="24dp"
            android:text="Grocery List"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />
    </RelativeLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardListContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-30dp"
        android:layout_marginBottom="-32dp"
        app:cardCornerRadius="32dp"
        app:cardBackgroundColor="#FAF8F6"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomButtonBar"
        app:layout_constraintTop_toBottomOf="@+id/headerBg">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingTop="32dp">

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No items to buy.\nTap + to add to list!"
                android:textAlignment="center"
                android:textColor="#BCAAA4"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.3" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGroceryList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="100dp"
                android:overScrollMode="never"
                tools:listitem="@layout/item_grocery" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddGrocery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#9A5B30"
        app:tint="@color/white"
        app:elevation="4dp"
        app:fabCustomSize="56dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomButtonBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/bottomButtonBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:background="@android:color/white"
        android:elevation="16dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearList"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:text="Clear All"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="#BA1A1A"
            android:fontFamily="sans-serif-medium"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconTint="#BA1A1A"
            app:rippleColor="#FEECEB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMoveToPantry"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Move to Pantry"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-medium"
            android:enabled="false"
            app:backgroundTint="#9A5B30"
            app:icon="@android:drawable/ic_menu_send"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            app:cornerRadius="24dp"
            app:elevation="2dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>