<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FAF8F6">

        <RelativeLayout
            android:id="@+id/layoutTopBanner"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_home_top_banner"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:scaleType="centerInside"
                app:tint="#FFFFFF"
                android:importantForAccessibility="no" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivHomeLogo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="24dp"
                android:src="@drawable/logo"
                android:background="@android:color/white"
                android:padding="5dp"
                android:elevation="4dp"
                app:shapeAppearanceOverlay="@style/CircleShape"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="1.5dp"
                android:importantForAccessibility="no" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@+id/layoutTopBanner"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="4dp"
                android:paddingBottom="32dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="2dp">

                    <TextView
                        android:id="@+id/tvWelcomeTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good afternoon,"
                        android:textColor="#8D6E63"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-light" />

                    <TextView
                        android:id="@+id/tvHomeUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chef!"
                        android:textColor="#5E3924"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR PANTRY PANELS"
                    android:textColor="#BCAAA4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="2dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="26dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#EFE7E2"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="@android:color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingVertical="16dp">
                            <TextView android:id="@+id/tvHomePantryCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="20sp" android:textStyle="bold" android:textColor="#5E3924" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Items" android:textSize="12sp" android:textColor="#8D6E63" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#EFE7E2"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="@android:color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingVertical="16dp">
                            <TextView android:id="@+id/tvHomeFavCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="20sp" android:textStyle="bold" android:textColor="#5E3924" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Favorites" android:textSize="12sp" android:textColor="#8D6E63" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#FFEBEE"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="#FFFDFD">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingVertical="16dp">
                            <TextView android:id="@+id/tvHomeExpiringCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="20sp" android:textStyle="bold" android:textColor="#D32F2F" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Expiring" android:textSize="12sp" android:textColor="#D32F2F" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <RelativeLayout
                    android:id="@+id/btnUpdatePantry"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_btn_orange_gradient"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/ivIcon1" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerVertical="true" android:src="@android:drawable/ic_menu_edit" app:tint="@color/white" android:importantForAccessibility="no" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/ivIcon1" android:layout_centerVertical="true" android:layout_marginStart="14dp" android:text="Update Your Pantry" android:textColor="@color/white" android:textStyle="bold" android:textSize="14sp" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/btnExploreRecipes"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_btn_green_gradient"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/ivIcon2" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerVertical="true" android:src="@android:drawable/ic_menu_search" app:tint="@color/white" android:importantForAccessibility="no" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/ivIcon2" android:layout_centerVertical="true" android:layout_marginStart="14dp" android:text="Explore Recommended Recipes" android:textColor="@color/white" android:textStyle="bold" android:textSize="14sp" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/btnGroceryList"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/bg_btn_brown_gradient"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/ivIcon3" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerVertical="true" android:src="@android:drawable/ic_menu_agenda" app:tint="@color/white" android:importantForAccessibility="no" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/ivIcon3" android:layout_centerVertical="true" android:layout_marginStart="14dp" android:text="View Grocery List" android:textColor="@color/white" android:textStyle="bold" android:textSize="14sp" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:paddingHorizontal="2dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="SUGGESTED FOR YOU"
                        android:textColor="#BCAAA4"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />
                    <TextView
                        android:id="@+id/tvHomeViewAllRecipes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="View all"
                        android:textColor="#9A5B30"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:padding="4dp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHomeSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    android:layout_marginBottom="16dp"
                    tools:listitem="@android:layout/activity_list_item" />
            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        android:background="#FAF8F6"
        app:itemIconTint="#5E3924"
        app:itemTextColor="#5E3924">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EFE7E2"
                android:layout_marginBottom="16dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Language"
                    android:textColor="#5E3924"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvLangEN"
                        android:layout_width="32dp"
                        android:layout_height="match_parent"
                        android:text="EN"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#9A5B30"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchLanguageToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="2dp"
                        app:thumbTint="#9A5B30"
                        app:trackTint="#EFE7E2"/>

                    <TextView
                        android:id="@+id/tvLangTR"
                        android:layout_width="32dp"
                        android:layout_height="match_parent"
                        android:text="TR"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="#BCAAA4"/>
                </LinearLayout>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="44dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Theme"
                    android:textColor="#5E3924"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvThemeDarkIcon"
                        android:layout_width="28dp"
                        android:layout_height="match_parent"
                        android:text="🌙"
                        android:gravity="center"
                        android:textSize="14sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchThemeToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="2dp"
                        app:thumbTint="#9A5B30"
                        app:trackTint="#EFE7E2"/>

                    <TextView
                        android:id="@+id/tvThemeLightIcon"
                        android:layout_width="28dp"
                        android:layout_height="match_parent"
                        android:text="☀️"
                        android:gravity="center"
                        android:textSize="14sp" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>